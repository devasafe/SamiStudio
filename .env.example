# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (MongoDB Atlas)
MONGODB_URI=

# Auth
JWT_SECRET=

# Seed do admin (npm run db:seed)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Contato
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics — enviar dados (script no site). GA4 > Admin > Fluxos de dados.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Analytics — ler dados (gráfico do dashboard). Nunca use NEXT_PUBLIC nestes:
# a chave privada vazaria para o navegador de quem visita o site.
# GA4 > Admin > Configurações da propriedade > ID da propriedade (número).
GA_PROPERTY_ID=
# Conta de serviço do Google Cloud com a Google Analytics Data API ativada,
# adicionada como Leitor na propriedade do GA4.
GA_CLIENT_EMAIL=
# Do JSON da chave, campo "private_key" — entre aspas, com os \n literais.
GA_PRIVATE_KEY=

# Search Console (meta de verificação)
GOOGLE_SITE_VERIFICATION=
